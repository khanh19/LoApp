# Encore API (run `encore run` from lo-app-backend; default gateway is port 4000)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Optional: Auth0 connection names (must match Authentication → Social → connection name,
# and be enabled for your Auth0 Application). Defaults: apple, google-oauth2, facebook
# EXPO_PUBLIC_AUTH0_CONNECTION_APPLE=apple
# EXPO_PUBLIC_AUTH0_CONNECTION_GOOGLE=google-oauth2
# EXPO_PUBLIC_AUTH0_CONNECTION_FACEBOOK=facebook
