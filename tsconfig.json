{
  "extends": ["expo/tsconfig.base", "@react-native/typescript-config"],
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-native",
    "module": "esnext",
    "paths": {
      "@/*": ["./*"],
      "@/screens/*": ["./src/screens/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/data/*": ["./src/data/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/constants": ["./src/constants.ts"],
      "@/theme": ["./src/theme.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
